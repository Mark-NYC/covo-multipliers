  <script>
    const toggleTraining = document.getElementById('toggle-training');
    const toggleImmersion = document.getElementById('toggle-immersion');
    const experienceImage = document.getElementById('experience-image');
    const experienceKicker = document.getElementById('experience-kicker');
    const experienceTitle = document.getElementById('experience-title');
    const experienceCopy = document.getElementById('experience-copy');

    function setExperienceState(state) {
      const isTraining = state === 'training';

      toggleTraining.classList.toggle('active', isTraining);
      toggleImmersion.classList.toggle('active', !isTraining);

      toggleTraining.setAttribute('aria-selected', isTraining ? 'true' : 'false');
      toggleImmersion.setAttribute('aria-selected', isTraining ? 'false' : 'true');

      if (isTraining) {
        experienceImage.src = 'image/immersions/whiteboard classroom training.webp';
        experienceImage.alt = 'Person teaching at a whiteboard in a classroom setting';
        experienceKicker.textContent = 'Most training';
        experienceTitle.textContent = 'Hear it. Practice some. Imagine the rest.';
        experienceCopy.textContent = 'Good training gives you language and tools. Sometimes it even gives you practice. But most people still go home trying to picture what this looks like in actual homes, workplaces, neighborhoods, and weekly rhythms.';
      } else {
        experienceImage.src = 'image/immersions/hands on immersion.webp';
        experienceImage.alt = 'Hands-on immersion experience in a lived-in setting';
        experienceKicker.textContent = 'Immersion';
        experienceTitle.textContent = 'Hear it. Practice it. Experience it.';
        experienceCopy.textContent = 'Immersion adds what most training cannot. You watch this lived out in real settings, ask questions as it happens, and go home with a picture you can actually reproduce.';
      }
    }

    toggleTraining.addEventListener('click', function() {
      setExperienceState('training');
    });

    toggleImmersion.addEventListener('click', function() {
      setExperienceState('immersion');
    });

    const slider = document.getElementById('immersion-slides');
    const sliderStage = document.getElementById('immersion-slider-stage');
    const dots = Array.from(document.querySelectorAll('.immersion-slider-dot'));
    const slides = Array.from(document.querySelectorAll('.immersion-slide'));

    let currentSlide = 0;
    let sliderInterval = null;
    let isDragging = false;
    let startX = 0;
    let currentTranslate = 0;
    let prevTranslate = 0;

    function getSlideWidth() {
      if (!slides.length) return 0;
      const gap = parseFloat(window.getComputedStyle(slider).gap) || 0;
      return slides[0].offsetWidth + gap;
    }

    function setSliderTransition(enabled) {
      slider.style.transition = enabled ? 'transform 0.45s ease' : 'none';
    }

    function updateDots() {
      dots.forEach(function(dot, i) {
        dot.classList.toggle('active', i === currentSlide);
      });
    }

    function goToSlide(index, withTransition = true) {
      const total = slides.length;
      currentSlide = ((index % total) + total) % total;
      const slideWidth = getSlideWidth();
      setSliderTransition(withTransition);
      currentTranslate = -(currentSlide * slideWidth);
      prevTranslate = currentTranslate;
      slider.style.transform = 'translateX(' + currentTranslate + 'px)';
      updateDots();
    }

    function startSlider() {
      stopSlider();
      sliderInterval = setInterval(function() {
        goToSlide(currentSlide + 1, true);
      }, 4500);
    }

    function stopSlider() {
      if (sliderInterval) {
        clearInterval(sliderInterval);
        sliderInterval = null;
      }
    }

    dots.forEach(function(dot, index) {
      dot.addEventListener('click', function() {
        goToSlide(index, true);
        startSlider();
      });
    });

    function pointerDown(clientX) {
      isDragging = true;
      startX = clientX;
      stopSlider();
      setSliderTransition(false);
    }

    function pointerMove(clientX) {
      if (!isDragging) return;
      const deltaX = clientX - startX;
      currentTranslate = prevTranslate + deltaX;
      slider.style.transform = 'translateX(' + currentTranslate + 'px)';
    }

    function pointerUp(clientX) {
      if (!isDragging) return;
      isDragging = false;

      const movedBy = clientX - startX;
      const threshold = Math.min(90, getSlideWidth() * 0.18);

      if (movedBy < -threshold) {
        currentSlide += 1;
      } else if (movedBy > threshold) {
        currentSlide -= 1;
      }

      goToSlide(currentSlide, true);
      startSlider();
    }

    sliderStage.addEventListener('touchstart', function(e) {
      if (e.touches.length !== 1) return;
      pointerDown(e.touches[0].clientX);
    }, { passive: true });

    sliderStage.addEventListener('touchmove', function(e) {
      if (e.touches.length !== 1) return;
      pointerMove(e.touches[0].clientX);
    }, { passive: true });

    sliderStage.addEventListener('touchend', function(e) {
      const touch = e.changedTouches[0];
      if (!touch) return;
      pointerUp(touch.clientX);
    });

    sliderStage.addEventListener('mousedown', function(e) {
      pointerDown(e.clientX);
    });

    window.addEventListener('mousemove', function(e) {
      pointerMove(e.clientX);
    });

    window.addEventListener('mouseup', function(e) {
      pointerUp(e.clientX);
    });

    sliderStage.addEventListener('mouseenter', stopSlider);

    sliderStage.addEventListener('mouseleave', function() {
      if (!isDragging) startSlider();
    });

    sliderStage.addEventListener('focusin', stopSlider);

    sliderStage.addEventListener('focusout', function() {
      if (!isDragging) startSlider();
    });

    window.addEventListener('resize', function() {
      goToSlide(currentSlide, false);
    });

    goToSlide(0, false);
    startSlider();

    /* ── Immersion cards + application modal ─────────────── */

    (function () {
      var SUPABASE_URL = 'https://mryjrvinzbxebzvxtggi.supabase.co';
      var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1yeWpydmluemJ4ZWJ6dnh0Z2dpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYyNzQ3MzksImV4cCI6MjA5MTg1MDczOX0.U1JJQTBVKePsVFXr2oFRCdUZasWaZiTQg6g8QrFdRyw';
      var EDGE_FUNCTION_URL = 'https://mryjrvinzbxebzvxtggi.supabase.co/functions/v1/immersion-apply';

      var _lastFocusedBtn = null;

      function escHtml(str) {
        if (str == null) return '';
        return String(str)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#x27;');
      }

      function formatDates(start, end) {
        if (!start) return '—';
        try {
          var s = new Date(start + 'T00:00:00');
          if (!end) {
            return new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(s);
          }
          var e = new Date(end + 'T00:00:00');
          if (s.getFullYear() === e.getFullYear() && s.getMonth() === e.getMonth()) {
            return new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' }).format(s) + '–' + e.getDate() + ', ' + e.getFullYear();
          }
          return new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' }).format(s) + ' – ' + new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(e);
        } catch (err) {
          return String(start);
        }
      }

      function buildSeatIndicator(remaining) {
        var count = Math.min(remaining, 10);
        var pips = '';
        for (var i = 0; i < count; i++) {
          pips += '<span class="seat-pip" aria-hidden="true"></span>';
        }
        var label = remaining === 1 ? '1 seat remaining' : remaining + ' seats remaining';
        return '<div class="seat-pips">' + pips + '</div><span class="seat-label">' + label + '</span>';
      }

      function buildCard(im) {
        var seats = Number(im.seats_remaining);
        var isWaitlist = seats <= 0;
        var seatHtml = isWaitlist
          ? '<span class="waitlist-badge">Waitlist open</span>'
          : buildSeatIndicator(seats);
        var dateStr = formatDates(im.start_date, im.end_date);

        return '<article class="immersion-card">' +
          '<h3 class="immersion-card-title">' + escHtml(im.title) + '</h3>' +
          '<ul class="immersion-card-meta">' +
            '<li><span class="meta-label">City</span><span class="meta-value">' + escHtml(im.city || '—') + '</span></li>' +
            '<li><span class="meta-label">Dates</span><span class="meta-value">' + escHtml(dateStr) + '</span></li>' +
            '<li><span class="meta-label">Format</span><span class="meta-value">' + escHtml(im.format || '—') + '</span></li>' +
            '<li><span class="meta-label">Focus</span><span class="meta-value">' + escHtml(im.platform_focus || '—') + '</span></li>' +
          '</ul>' +
          '<div class="seat-indicator">' + seatHtml + '</div>' +
          '<div class="immersion-card-cta">' +
            '<button class="btn-apply' + (isWaitlist ? ' is-waitlist' : '') + '" type="button"' +
              ' data-immersion-id="' + escHtml(String(im.id)) + '"' +
              ' data-immersion-title="' + escHtml(im.title) + '"' +
              ' data-waitlist="' + (isWaitlist ? 'true' : 'false') + '">' +
              (isWaitlist ? 'Join the waitlist' : 'Apply for this immersion') +
            '</button>' +
          '</div>' +
        '</article>';
      }

      function attachCardHandlers(grid) {
        grid.querySelectorAll('.btn-apply').forEach(function (btn) {
          btn.addEventListener('click', function () {
            openModal(
              btn.dataset.immersionId,
              btn.dataset.immersionTitle,
              btn.dataset.waitlist === 'true',
              btn
            );
          });
        });
      }

      function loadImmersionCards() {
        var grid = document.getElementById('immersion-cards-grid');
        if (!grid) return Promise.resolve();

        grid.innerHTML = '<div class="immersion-cards-loading">Loading available immersions…</div>';

        var url = new URL(SUPABASE_URL + '/rest/v1/immersions_with_availability');
        url.searchParams.set('select', '*');
        url.searchParams.set('status', 'eq.open');
        url.searchParams.set('order', 'start_date.asc');
        url.searchParams.set('limit', '3');

        return fetch(url.toString(), {
          headers: {
            'apikey': SUPABASE_ANON_KEY,
            'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
          },
        })
          .then(function (res) {
            if (!res.ok) throw new Error('Request failed');
            return res.json();
          })
          .then(function (data) {
            if (!Array.isArray(data) || data.length === 0) {
              grid.innerHTML = '<p class="immersion-cards-empty">No immersions are currently open. Check back soon.</p>';
              return;
            }
            grid.innerHTML = data.map(buildCard).join('');
            attachCardHandlers(grid);
          })
          .catch(function () {
            grid.innerHTML = '<p class="immersion-cards-empty">Unable to load immersions right now. Please try again shortly.</p>';
          });
      }

      function openModal(id, title, isWaitlist, triggerBtn) {
        var modal   = document.getElementById('apply-modal');
        var heading = document.getElementById('modal-heading');
        var hidden  = document.getElementById('apply-immersion-id');
        var form    = document.getElementById('immersion-apply-form');
        var success = document.getElementById('modal-success');
        var errorEl = document.getElementById('form-error');
        var submitBtn = form ? form.querySelector('.btn-submit') : null;

        if (hidden)  hidden.value = id;
        if (heading) heading.textContent = isWaitlist
          ? 'Join Waitlist — ' + title
          : 'Apply for ' + title;

        /* reset form to pristine state */
        if (form) {
          form.reset();
          form.hidden = false;
        }
        if (success) success.hidden = true;
        if (errorEl) errorEl.hidden = true;
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit Application';
        }

        _lastFocusedBtn = triggerBtn || document.activeElement;

        modal.hidden = false;
        document.body.style.overflow = 'hidden';

        /* move focus into modal */
        var firstFocusable = modal.querySelector(
          'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
        );
        if (firstFocusable) firstFocusable.focus();
      }

      function closeModal() {
        var modal = document.getElementById('apply-modal');
        modal.hidden = true;
        document.body.style.overflow = '';
        if (_lastFocusedBtn && _lastFocusedBtn.focus) {
          _lastFocusedBtn.focus();
        }
        _lastFocusedBtn = null;
      }

      /* close button */
      var closeBtn = document.getElementById('modal-close-btn');
      if (closeBtn) closeBtn.addEventListener('click', closeModal);

      /* success-state close button */
      var successCloseBtn = document.getElementById('modal-success-close-btn');
      if (successCloseBtn) {
        successCloseBtn.addEventListener('click', closeModal);
      }

      /* click outside panel */
      var modal = document.getElementById('apply-modal');
      if (modal) {
        modal.addEventListener('click', function (e) {
          if (e.target === modal) closeModal();
        });
      }

      /* Escape key */
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          var m = document.getElementById('apply-modal');
          if (m && !m.hidden) closeModal();
        }
      });

      /* focus trap inside modal */
      if (modal) {
        modal.addEventListener('keydown', function (e) {
          if (e.key !== 'Tab') return;
          var focusable = Array.from(modal.querySelectorAll(
            'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
          )).filter(function (el) { return !el.hidden && el.offsetParent !== null; });
          if (!focusable.length) return;
          var first = focusable[0];
          var last  = focusable[focusable.length - 1];
          if (e.shiftKey) {
            if (document.activeElement === first) { e.preventDefault(); last.focus(); }
          } else {
            if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
          }
        });
      }

      var applyForm = document.getElementById('immersion-apply-form');
      if (applyForm) {
        applyForm.addEventListener('submit', function (e) {
          e.preventDefault();

          var form      = e.target;
          var submitBtn = form.querySelector('.btn-submit');
          var errorEl   = document.getElementById('form-error');
          var successEl = document.getElementById('modal-success');

          var immersionId = form.immersion_id.value;
          if (!immersionId) {
            errorEl.textContent = 'No immersion selected. Please close and click "Apply for this immersion" on a card.';
            errorEl.hidden = false;
            return;
          }

          submitBtn.disabled = true;
          submitBtn.textContent = 'Submitting…';
          errorEl.hidden = true;

          var payload = {
            immersion_id:        immersionId,
            name:                form.name.value.trim(),
            email:               form.email.value.trim(),
            phone:               form.phone.value.trim(),
            city_state:          form.city_state.value.trim(),
            church_org:          form.church_org.value.trim(),
            team_status:         form.team_status.value,
            team_size:           Number(form.team_size.value) || 1,
            why_coming:          form.why_coming.value.trim(),
            hoping_to_learn:     form.hoping_to_learn.value.trim(),
            prior_training:      form.prior_training.value.trim(),
            lodging_acknowledged: form.lodging_acknowledged.checked,
          };

          fetch(EDGE_FUNCTION_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          })
            .then(function (res) {
              if (!res.ok) {
                return res.json().catch(function () { return {}; }).then(function (body) {
                  throw new Error(body.error || 'Something went wrong. Please try again.');
                });
              }
              return res;
            })
            .then(function () {
              form.reset();
              form.hidden = true;
              if (successEl) successEl.hidden = false;
              loadImmersionCards();
              /* focus the close button inside the success message */
              var sc = document.getElementById('modal-success-close-btn');
              if (sc) sc.focus();
            })
            .catch(function (err) {
              errorEl.textContent = err.message || 'Something went wrong. Please try again.';
              errorEl.hidden = false;
              submitBtn.disabled = false;
              submitBtn.textContent = 'Submit Application';
            });
        });
      }

      loadImmersionCards();
    })();

    document.querySelectorAll('.faq-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var item = btn.closest('.faq-item');
        var answer = item.querySelector('.faq-answer');
        var isOpen = item.classList.contains('is-open');

        document.querySelectorAll('.faq-item.is-open').forEach(function(open) {
          open.classList.remove('is-open');
          open.querySelector('.faq-btn').setAttribute('aria-expanded', 'false');
          open.querySelector('.faq-answer').hidden = true;
        });

        if (!isOpen) {
          item.classList.add('is-open');
          btn.setAttribute('aria-expanded', 'true');
          answer.hidden = false;
        }
      });
    });
  </script>

</body>
</html>

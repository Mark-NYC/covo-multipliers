<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Covo Immersions</title>

  <meta
    name="description"
    content="You’ve had the training. Now see disciple-making in real life through homes, workplaces, neighborhoods, businesses, and normal rhythms."
  />

  <link rel="stylesheet" href="styles.css" />

  <style>
    .site-header {
      background: #ffffff;
      border-bottom: 1px solid #e5e7eb;
      padding: 1rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .site-header .brand {
      font-size: 0.95rem;
      font-weight: 900;
      color: #10281f;
      text-decoration: none;
      letter-spacing: -0.01em;
    }

    .site-header .back-link {
      font-size: 0.875rem;
      color: #5a6b65;
      text-decoration: none;
      transition: color 0.15s ease;
    }

    .site-header .back-link:hover {
      color: #1b4d3e;
    }

    .immersion-hero {
      padding: 3.75rem 2rem 3.25rem;
      background: linear-gradient(
        135deg,
        #0f1720 0%,
        #143129 24%,
        #1f4d46 48%,
        #4e5f6b 72%,
        #c18a3a 100%
      );
      position: relative;
      overflow: hidden;
    }

    .immersion-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.12;
      background-image:
        radial-gradient(circle at 20% 20%, rgba(255,255,255,0.12) 0.7px, transparent 0.8px),
        radial-gradient(circle at 80% 30%, rgba(0,0,0,0.10) 0.7px, transparent 0.8px),
        radial-gradient(circle at 40% 70%, rgba(255,255,255,0.08) 0.6px, transparent 0.7px),
        radial-gradient(circle at 70% 80%, rgba(0,0,0,0.08) 0.6px, transparent 0.7px);
      background-size: 120px 120px, 140px 140px, 100px 100px, 160px 160px;
      mix-blend-mode: soft-light;
    }

    .immersion-hero-inner {
      max-width: 1160px;
      margin: 0 auto;
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 430px;
      gap: 3rem;
      align-items: center;
    }

    .hero-copy {
      min-width: 0;
    }

    .hero-image-wrap {
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 24px 64px rgba(0, 0, 0, 0.38);
      aspect-ratio: 4 / 3;
      background: rgba(255,255,255,0.08);
    }

    .hero-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .event-label {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.62);
      margin-bottom: 1rem;
    }

    .event-title {
      font-size: clamp(2.8rem, 6vw, 4.8rem);
      font-weight: 900;
      color: #ffffff;
      line-height: 0.95;
      letter-spacing: -0.05em;
      margin-bottom: 1rem;
      max-width: 760px;
    }

    .hero-lead {
      font-size: clamp(1.1rem, 2vw, 1.34rem);
      line-height: 1.55;
      color: rgba(255,255,255,0.94);
      max-width: 760px;
      margin-bottom: 1.35rem;
    }

    .hero-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
      margin-top: 0.3rem;
    }

    .hero-cta-row .btn-pill {
      border-color: rgba(255,255,255,0.92);
      color: #ffffff;
    }

    .hero-cta-row .btn-pill:hover {
      background: #ffffff;
      color: #10281f;
      border-color: #ffffff;
    }

    .hero-cta-row .btn-pill-primary {
      background: #ffffff;
      color: #10281f;
      border-color: #ffffff;
      box-shadow: 0 10px 24px rgba(16, 40, 31, 0.16);
    }

    .hero-cta-row .btn-pill-primary:hover {
      background: #f5f5f5;
      color: #10281f;
      border-color: #f5f5f5;
    }

    .hero-support-line {
      font-size: 0.88rem;
      line-height: 1.5;
      color: rgba(255,255,255,0.78);
      margin-top: 0.85rem;
    }

    .btn-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.95rem 1.5rem;
      border-radius: 999px;
      background: #dcb55a;
      color: #10281f;
      border: 1px solid #dcb55a;
      font-size: 0.95rem;
      font-weight: 800;
      letter-spacing: -0.01em;
      text-decoration: none;
      line-height: 1;
      transition: background 0.18s ease, border-color 0.18s ease, transform 0.18s ease, color 0.18s ease;
      box-shadow: 0 10px 24px rgba(16, 40, 31, 0.16);
    }

    .btn-cta:hover {
      background: #e7c574;
      border-color: #e7c574;
      color: #10281f;
      transform: translateY(-1px);
    }

    .btn-cta:active {
      transform: translateY(0);
    }

    .btn-cta:focus-visible {
      outline: 3px solid rgba(255, 255, 255, 0.4);
      outline-offset: 3px;
    }

    .page-section {
      background: #ffffff;
      padding: 3.5rem 2rem;
      border-bottom: 1px solid #e5e7eb;
    }

    .page-section-inner {
      max-width: 960px;
      margin: 0 auto;
    }

    .two-col-section .page-section-inner {
      max-width: 1200px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 400px;
      gap: 4rem;
      align-items: start;
    }

    .eyebrow {
      display: block;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #245c4a;
      margin-bottom: 0.55rem;
    }

    .section-title {
      font-size: clamp(1.9rem, 3vw, 2.7rem);
      font-weight: 900;
      color: #10281f;
      line-height: 1.02;
      letter-spacing: -0.04em;
      margin-bottom: 1rem;
      max-width: 760px;
    }

    .section-copy {
      font-size: 1rem;
      line-height: 1.72;
      color: #444444;
      max-width: 760px;
    }

    .section-copy p + p {
      margin-top: 0.85rem;
    }

    .simple-list {
      list-style: none;
      padding: 0;
      margin: 1.4rem 0 0;
    }

    .simple-list li {
      display: flex;
      align-items: flex-start;
      gap: 0.9rem;
      padding: 1rem 0;
      border-bottom: 1px solid #f0f0f0;
      font-size: 1rem;
      line-height: 1.65;
      color: #2a2a2a;
    }

    .simple-list li:last-child {
      border-bottom: none;
    }

    .simple-check {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: #f0fdf4;
      border: 1.5px solid #bbf7d0;
      font-size: 0.6rem;
      font-weight: 800;
      color: #15803d;
      margin-top: 0.25rem;
    }

    .experience-toggle-wrap {
      margin-top: 1.6rem;
      background: #f8faf9;
      border: 1px solid #e2eae6;
      border-radius: 20px;
      padding: 1.2rem;
    }

    .experience-toggle-shell {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: #edf2ee;
      border: 1px solid #d9e4dc;
      border-radius: 999px;
      padding: 0.3rem;
      margin-bottom: 1rem;
    }

    .experience-toggle-btn {
      border: none;
      background: transparent;
      color: #3f514a;
      font-size: 0.92rem;
      font-weight: 800;
      padding: 0.72rem 1.15rem;
      border-radius: 999px;
      cursor: pointer;
      transition: background 0.22s ease, color 0.22s ease, box-shadow 0.22s ease;
      font-family: inherit;
    }

    .experience-toggle-btn.active {
      background: #8fd19e;
      color: #10281f;
      box-shadow: 0 4px 12px rgba(16, 40, 31, 0.10);
    }

    .experience-panel {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 1.2rem;
      align-items: start;
    }

    .experience-image-wrap {
      border-radius: 16px;
      overflow: hidden;
      background: #ffffff;
      box-shadow: 0 8px 24px rgba(16, 40, 31, 0.08);
      aspect-ratio: 4 / 3;
      width: 100%;
    }

    .experience-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .experience-copy {
      min-width: 0;
      align-self: start;
      padding-top: 0.1rem;
    }

    .experience-kicker {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #245c4a;
      margin-bottom: 0.55rem;
    }

    .experience-state-title {
      font-size: clamp(1.55rem, 2.3vw, 2.15rem);
      font-weight: 900;
      color: #10281f;
      line-height: 1.02;
      letter-spacing: -0.04em;
      margin-bottom: 0.75rem;
    }

    .experience-state-copy {
      font-size: 0.98rem;
      line-height: 1.7;
      color: #444444;
    }

    .immersion-slider-wrap {
      margin-top: 1.8rem;
      background: #f8faf9;
      border: 1px solid #e2eae6;
      border-radius: 20px;
      padding: 1.2rem;
      overflow: hidden;
      touch-action: pan-y;
    }

    .immersion-slider-stage {
      position: relative;
      overflow: hidden;
    }

    .immersion-slides {
      display: flex;
      gap: 1rem;
      transition: transform 0.45s ease;
      will-change: transform;
    }

    .immersion-slide {
      flex: 0 0 calc(100% - 1rem);
      min-width: calc(100% - 1rem);
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 1.2rem;
      align-items: start;
    }

    .immersion-slide-image {
      border-radius: 16px;
      overflow: hidden;
      background: #ffffff;
      box-shadow: 0 8px 24px rgba(16, 40, 31, 0.08);
      aspect-ratio: 4 / 3;
      width: 100%;
    }

    .immersion-slide-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .immersion-slide-copy {
      min-width: 0;
      align-self: start;
      padding-top: 0.1rem;
    }

    .immersion-slide-kicker {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #245c4a;
      margin-bottom: 0.55rem;
    }

    .immersion-slide-title {
      font-size: clamp(1.45rem, 2vw, 2rem);
      font-weight: 900;
      color: #10281f;
      line-height: 1.04;
      letter-spacing: -0.03em;
      margin-bottom: 0.75rem;
    }

    .immersion-slide-text {
      font-size: 0.98rem;
      line-height: 1.7;
      color: #444444;
    }

    .immersion-slider-dots {
      display: flex;
      justify-content: center;
      gap: 0.55rem;
      margin-top: 1rem;
    }

    .immersion-slider-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      border: none;
      background: #cfd8d3;
      cursor: pointer;
      transition: transform 0.2s ease, background 0.2s ease;
      padding: 0;
    }

    .immersion-slider-dot.active {
      background: #1b4d3e;
      transform: scale(1.15);
    }

    .split-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      margin-top: 1.5rem;
    }

    .split-card {
      background: #f8faf9;
      border: 1px solid #e2eae6;
      border-radius: 16px;
      padding: 1.45rem 1.5rem;
    }

    .split-card h3 {
      font-size: 1.1rem;
      font-weight: 900;
      color: #10281f;
      line-height: 1.12;
      letter-spacing: -0.02em;
      margin-bottom: 0.85rem;
    }

    .icon-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .icon-list li {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      font-size: 0.97rem;
      line-height: 1.65;
      color: #3a4a44;
      padding: 0.38rem 0;
    }

    .icon-list-mark {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 20px;
      font-size: 0.85rem;
      font-weight: 900;
      margin-top: 0.1rem;
    }

    .icon-list-mark.is-yes {
      color: #15803d;
    }

    .icon-list-mark.is-no {
      color: #dc2626;
    }

    .info-card {
      background: #ffffff;
      border-radius: 16px;
      border-top: 4px solid #1b4d3e;
      box-shadow:
        0 4px 6px rgba(0, 0, 0, 0.04),
        0 12px 40px rgba(16, 40, 31, 0.10);
      padding: 2.1rem 2.2rem;
      position: sticky;
      top: 1rem;
    }

    .info-card h2 {
      font-size: 1.45rem;
      font-weight: 900;
      color: #10281f;
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: 0.35rem;
    }

    .info-card-intro {
      font-size: 0.9rem;
      color: #5a6b65;
      line-height: 1.55;
      margin-bottom: 1.35rem;
    }

    .info-list {
      list-style: none;
      padding: 0;
      margin: 0 0 1.35rem;
    }

    .info-list li {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.95rem 0;
      border-bottom: 1px solid #edf1ef;
      font-size: 0.94rem;
      line-height: 1.5;
    }

    .info-list li:last-child {
      border-bottom: none;
    }

    .info-label {
      font-weight: 800;
      color: #10281f;
    }

    .info-value {
      text-align: right;
      color: #5a6b65;
    }

    .btn-card {
      width: 100%;
      text-align: center;
    }

    .info-card-secondary {
      margin-top: 0.9rem;
      text-align: center;
      font-size: 0.88rem;
      color: #5a6b65;
    }

    .info-card-secondary a {
      color: #1b4d3e;
      font-weight: 700;
      text-decoration: underline;
      text-underline-offset: 0.15em;
    }

.day-rhythm-section {
  background: #f8faf9;
}

.day-rhythm-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1rem;
  margin-top: 1.6rem;
}

.day-rhythm-card {
  background: #ffffff;
  border: 1px solid #e2eae6;
  border-radius: 18px;
  padding: 1.4rem 1.25rem;
  box-shadow: 0 4px 18px rgba(16, 40, 31, 0.06);
}

.day-rhythm-icon {
  width: 42px;
  height: 42px;
  border-radius: 999px;
  background: #edf7ef;
  border: 1px solid #d5ead9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1rem;
}

.day-rhythm-icon svg {
  width: 22px;
  height: 22px;
  stroke: #1b4d3e;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.day-rhythm-card h3 {
  font-size: 1.05rem;
  font-weight: 900;
  color: #10281f;
  letter-spacing: -0.02em;
  margin-bottom: 0.35rem;
}

.day-rhythm-card p {
  font-size: 0.95rem;
  line-height: 1.55;
  color: #3a4a44;
}

@media (max-width: 860px) {
  .day-rhythm-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 540px) {
  .day-rhythm-grid {
    grid-template-columns: 1fr;
  }
}
    
    .testimonials-section {
      background: #f8faf9;
      padding: 4rem 2rem;
      border-bottom: 1px solid #e5e7eb;
    }

    .testimonials-inner {
      max-width: 980px;
      margin: 0 auto;
    }

    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
      margin-top: 1.8rem;
    }

    .testimonial-card {
      background: #ffffff;
      border: 1px solid #e2eae6;
      border-radius: 16px;
      padding: 1.6rem 1.5rem;
      box-shadow: 0 2px 12px rgba(16, 40, 31, 0.06);
    }

    .testimonial-quote {
      font-size: 1.02rem;
      line-height: 1.7;
      color: #2a2a2a;
      font-style: italic;
    }

    .testimonial-attribution {
      margin-top: 1rem;
      font-size: 0.82rem;
      font-weight: 800;
      color: #1b4d3e;
      letter-spacing: 0.02em;
    }

    .faq-box {
      background: #f8faf9;
      border-left: 3px solid #1b4d3e;
      border-radius: 0 10px 10px 0;
      padding: 1.85rem 2rem;
    }

    .faq-box > strong {
      display: block;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #245c4a;
      margin-bottom: 1rem;
    }

    .faq-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .faq-item {
      border-bottom: 1px solid #e2eae6;
    }

    .faq-item:last-child {
      border-bottom: none;
    }

    .faq-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      background: none;
      border: none;
      padding: 1.1rem 0;
      cursor: pointer;
      font-family: inherit;
      font-size: 0.98rem;
      font-weight: 800;
      color: #10281f;
      text-align: left;
      line-height: 1.4;
    }

    .faq-btn:hover {
      color: #1b4d3e;
    }

    .faq-icon {
      flex-shrink: 0;
      font-size: 1.25rem;
      font-weight: 300;
      color: #245c4a;
      line-height: 1;
      transition: transform 0.2s ease;
    }

    .faq-item.is-open .faq-icon {
      transform: rotate(45deg);
    }

    .faq-answer {
      padding: 0 1rem 1.1rem 0;
      font-size: 0.94rem;
      line-height: 1.68;
      color: #3a4a44;
    }

    .bottom-cta {
      background: linear-gradient(
        135deg,
        #102018 0%,
        #17362d 35%,
        #2c4f57 70%,
        #b68539 100%
      );
      padding: 4.75rem 2rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .bottom-cta::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.1;
      background-image:
        radial-gradient(circle at 25% 25%, rgba(255,255,255,0.12) 0.7px, transparent 0.8px),
        radial-gradient(circle at 75% 75%, rgba(0,0,0,0.10) 0.7px, transparent 0.8px);
      background-size: 120px 120px, 160px 160px;
      mix-blend-mode: soft-light;
    }

    .bottom-cta-inner {
      max-width: 660px;
      margin: 0 auto;
      position: relative;
      z-index: 2;
    }

    .bottom-cta-headline {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 900;
      color: #ffffff;
      line-height: 0.98;
      letter-spacing: -0.05em;
      margin-bottom: 1rem;
    }

    .bottom-cta-body {
      font-size: 1.02rem;
      line-height: 1.75;
      color: rgba(255, 255, 255, 0.84);
      margin-bottom: 2rem;
    }

    .site-footer {
      background: #10281f;
      padding: 1.5rem 2rem;
      text-align: center;
    }

    .footer-brand {
      display: inline-block;
      font-size: 1rem;
      font-weight: 900;
      color: #ffffff;
      text-decoration: none;
      letter-spacing: -0.01em;
      margin-bottom: 0.25rem;
    }

    .footer-tagline {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.38);
      margin-bottom: 0.6rem;
    }

    .footer-copy {
      font-size: 0.8rem;
      color: rgba(255, 255, 255, 0.28);
    }

    @media (max-width: 980px) {
      .testimonials-grid,
      .split-grid,
      .experience-panel,
      .immersion-slide {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 860px) {
      .immersion-hero-inner,
      .two-col-section .page-section-inner {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .hero-image-wrap {
        aspect-ratio: 16 / 9;
      }

      .info-card {
        position: static;
      }
    }

    @media (max-width: 540px) {
      .immersion-hero,
      .page-section,
      .testimonials-section,
      .bottom-cta,
      .site-header,
      .site-footer {
        padding-left: 1.25rem;
        padding-right: 1.25rem;
      }

      .immersion-hero {
        padding-top: 1.4rem;
        padding-bottom: 1.2rem;
      }

      .event-title {
        font-size: clamp(2rem, 10vw, 2.95rem);
        line-height: 0.98;
      }

      .hero-lead {
        font-size: 1rem;
        line-height: 1.45;
      }

      .section-title {
        font-size: clamp(1.55rem, 7vw, 2rem);
      }

      .bottom-cta-headline {
        font-size: clamp(1.7rem, 8vw, 2.3rem);
      }

      .info-card,
